# Registry deployment configuration.
# Copy this file to .env and fill in your values.

# PostgreSQL connection string (overrides Docker Compose defaults if needed)
REGISTRY_DB_URL=postgres://registry:${POSTGRES_PASSWORD}@db:5432/registry?sslmode=disable

# Bind address (default 0.0.0.0:8080)
REGISTRY_BIND_ADDR=:8080

# Secret used to derive auth tokens
REGISTRY_AUTH_TOKEN_PEPPER=change-me-to-a-random-32-char-string

# Public-facing base URL (e.g. https://packages.kylix.top)
REGISTRY_BASE_URL=https://packages.kylix.top

# PostgreSQL password (used by docker-compose)
POSTGRES_PASSWORD=change-me-too