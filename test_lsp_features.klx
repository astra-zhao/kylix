program LSPTest;

var
  globalVar: integer;
  globalStr: string;

function Add(a, b: integer): integer;
begin
  result := a + b;
  globalVar := result;
end;

function Multiply(x, y: integer): integer;
begin
  result := x * y;
end;

procedure PrintResult(value: integer);
begin
  writeln('Result: ', value);
  globalStr := 'done';
end;

begin
  var sum := Add(5, 3);
  var product := Multiply(4, 6);

  PrintResult(sum);
  PrintResult(product);

  globalVar := 100;
  writeln(globalVar);
end.
